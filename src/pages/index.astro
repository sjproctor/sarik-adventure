---
import Layout from '../layouts/Layout.astro';
import Decor from '../components/Decor.astro';
import Meadow from '../components/Meadow.astro';

// Placeholder data — replaced by the `locations` content collection in a
// later milestone. `status` drives which accordion panel opens by default.
// Each photo's `caption` is optional — omit it for an uncaptioned tile.
type Photo = { caption?: string };
type Location = {
  name: string;
  region: string;
  status: string;
  dates: string;
  note: string;
  mapUrl: string;
  photos: Photo[];
};

const locations: Location[] = [
  {
    name: 'Sun Valley',
    region: 'Idaho',
    status: 'current',
    dates: 'May 2026',
    note: 'Placeholder notes about Sun Valley — trails, light, and the people we met.',
    // Placeholder — real Google Maps URL comes from the location frontmatter later.
    mapUrl: '#',
    photos: [
      { caption: 'Morning light on Bald Mountain.' },
      { caption: 'Trailhead before the long climb up.' },
      {},
      {},
    ],
  },
  {
    name: 'Bandon',
    region: 'Oregon',
    status: 'upcoming',
    dates: 'Next stop',
    note: 'Placeholder notes — coastline and sea stacks are on the itinerary.',
    mapUrl: '#',
    photos: [{ caption: 'Sea stacks at low tide.' }, {}, {}],
  },
];

const statusLabel: Record<string, string> = {
  current: 'Currently here',
  upcoming: 'Next up',
  visited: 'Visited',
};
---

<Layout>
  {/* ===== Hero: the "what & why", above the fold ===== */}
  <section class="relative overflow-hidden border-b border-ink/10 bg-sand">
    <Decor
      shape="rings"
      class="pointer-events-none absolute -right-12 -top-10 h-56 w-56 text-mustard/40"
    />
    {/* Bottom edge is the signature meadow band (below), so the hero reserves
        room for it with extra bottom padding. */}
    <div class="relative mx-auto max-w-5xl px-5 pt-20 pb-48 sm:pt-28 sm:pb-56">
      <p class="mb-4 inline-flex items-center gap-2 rounded-pill bg-terracotta/15 px-3 py-1 text-sm font-semibold text-terracotta">
        <Decor shape="starburst" class="h-4 w-4" /> A small travel journal
      </p>
      <h1 class="max-w-2xl text-5xl font-semibold text-ink sm:text-6xl">
        Postcards from the road.
      </h1>
      <p class="mt-5 max-w-xl text-lg text-ink-soft">
        Placeholder intro — the "what &amp; why" lives here: who we are, where
        we're headed, and why we packed up to chase good light and new places.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href="#locations"
          class="inline-flex min-h-11 items-center rounded-pill bg-teal px-6 font-medium text-cream transition-colors hover:bg-teal-deep"
        >
          See where we are
        </a>
        <a
          href="/musings"
          class="inline-flex min-h-11 items-center rounded-pill border border-ink/20 px-6 font-medium text-ink transition-colors hover:bg-cream"
        >
          Read the musings
        </a>
      </div>
    </div>

    {/* Signature meadow band, stems rising from the bottom edge. Width is
        constrained to the content column so its height stays bounded. */}
    <div class="pointer-events-none absolute inset-x-0 bottom-0">
      <div class="mx-auto max-w-5xl px-5">
        <Meadow class="w-full" />
      </div>
    </div>
  </section>

  {/* ===== Locations accordion (native <details>, zero-JS) ===== */}
  <section id="locations" class="mx-auto max-w-5xl px-5 py-16" aria-labelledby="locations-heading">
    <div class="mb-8 flex items-center gap-3">
      <Decor shape="boomerang" class="h-6 w-6 text-sage" />
      <h2 id="locations-heading" class="text-3xl font-semibold text-ink">Where we are</h2>
    </div>

    <div class="space-y-4">
      {
        locations.map((loc) => (
          <details
            open={loc.status === 'current'}
            class="group overflow-hidden rounded-soft border border-ink/10 bg-cream"
          >
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 [&::-webkit-details-marker]:hidden">
              <span class="flex items-baseline gap-3">
                <span class="font-display text-2xl font-semibold text-ink">{loc.name}</span>
                <span class="text-ink-soft">{loc.region}</span>
              </span>
              <span class="flex items-center gap-3">
                <span
                  class:list={[
                    'rounded-pill px-3 py-1 text-sm font-semibold',
                    loc.status === 'current'
                      ? 'bg-teal text-cream'
                      : 'bg-mustard/25 text-ink',
                  ]}
                >
                  {statusLabel[loc.status]}
                </span>
                <svg
                  class="h-5 w-5 shrink-0 text-ink-soft transition-transform group-open:rotate-180"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path
                    fill-rule="evenodd"
                    d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.06l3.71-3.83a.75.75 0 1 1 1.08 1.04l-4.25 4.39a.75.75 0 0 1-1.08 0L5.21 8.27a.75.75 0 0 1 .02-1.06Z"
                  />
                </svg>
              </span>
            </summary>

            <div class="border-t border-ink/10 px-5 py-5">
              <p class="mb-4 text-ink-soft">
                <span class="font-medium text-ink">{loc.dates}.</span> {loc.note}
              </p>
              {/* Placeholder Google Maps link — wired to real location coords later */}
              <a
                href={loc.mapUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="mb-5 inline-flex min-h-11 items-center gap-2 font-medium text-ink underline decoration-ink/30 underline-offset-4 transition-colors hover:text-teal hover:decoration-teal"
              >
                <svg class="h-5 w-5 shrink-0 text-terracotta" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path
                    fill-rule="evenodd"
                    d="M10 2a5.5 5.5 0 0 0-5.5 5.5c0 3.6 4.51 8.97 4.7 9.2a1.04 1.04 0 0 0 1.6 0c.19-.23 4.7-5.6 4.7-9.2A5.5 5.5 0 0 0 10 2Zm0 7.75a2.25 2.25 0 1 1 0-4.5 2.25 2.25 0 0 1 0 4.5Z"
                    clip-rule="evenodd"
                  />
                </svg>
                View on Google Maps
              </a>
              {/* Placeholder photo tiles — replaced by optimized images later */}
              <ul class="grid grid-cols-2 gap-3 sm:grid-cols-4">
                {loc.photos.map((photo, i) => (
                  <li>
                    <figure>
                      <div class="flex aspect-[4/3] items-center justify-center rounded-soft bg-sand text-sm font-medium text-ink-soft">
                        Photo {i + 1}
                      </div>
                      {photo.caption && (
                        <figcaption class="mt-2 text-sm text-ink-soft">{photo.caption}</figcaption>
                      )}
                    </figure>
                  </li>
                ))}
              </ul>
            </div>
          </details>
        ))
      }
    </div>
  </section>
</Layout>
