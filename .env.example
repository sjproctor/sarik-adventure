# EmailJS credentials for the contact form (src/components/ContactForm.tsx).
# These are NEXT_PUBLIC_ values — they ship in the client bundle and are not
# secret. Protect against abuse by setting Allowed Origins + a send quota in
# the EmailJS dashboard, not by hiding these.
#
# Copy this file to .env.local and fill in the values from your EmailJS account
# (https://dashboard.emailjs.com).
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
